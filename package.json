{
  "name": "smart-drift-detector",
  "version": "0.1.0",
  "description": "Deterministic code drift detection for AI-generated code",
  "main": "dist/index.js",
  "types": "dist/types/index.d.ts",
  "bin": {
    "smart-review": "dist/integration/cli.js"
  },
  "files": [
    "dist/",
    "skills/",
    ".agents/",
    ".claude-plugin/",
    ".codex-plugin/",
    ".cursor-plugin/"
  ],
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "tsc --noEmit"
  },
  "keywords": ["code-review", "ai", "static-analysis", "pre-commit"],
  "license": "MIT",
  "dependencies": {
    "commander": "^12.0.0",
    "js-yaml": "^4.1.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.4.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": ["**/tests/**/*.test.ts"],
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    },
    "transformIgnorePatterns": ["node_modules/"]
  }
}
